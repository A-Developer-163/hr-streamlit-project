# HR Employee Analytics - Environment Variables

# Data directory path (relative to project root)
DATA_DIR=data

# Path to HR employee data CSV file
HR_DATA_PATH=data/hr_employee_data.csv

# Models directory path (relative to project root)
MODELS_DIR=models

# Path to HR employee data Excel file
HR_EXCEL_DATA_PATH=data/hr_employee_data.xlsx

# Output paths
DRIFT_PLOT_PATH=models/drift_plot.png
SHAP_OUTPUT_DIR=models/shap
